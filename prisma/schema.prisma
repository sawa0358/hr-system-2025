generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id                             String                          @id @default(cuid())
  employeeId                     String                          @unique
  employeeNumber                 String                          @unique
  employeeType                   String
  name                           String
  furigana                       String?
  email                          String?
  phone                          String?
  department                     String
  position                       String
  organization                   String
  team                           String?
  joinDate                       DateTime
  status                         EmployeeStatus                  @default(active)
  password                       String
  rawPassword                    String?
  role                           UserRole?
  myNumber                       String?
  userId                         String?
  url                            String?
  address                        String?
  selfIntroduction               String?
  phoneInternal                  String?
  phoneMobile                    String?
  birthDate                      DateTime?
  avatar                         String?
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  showInOrgChart                 Boolean                         @default(true)
  parentEmployeeId               String?
  isInvisibleTop                 Boolean                         @default(false)
  isSuspended                    Boolean                         @default(false)
  retirementDate                 DateTime?
  privacyDisplayName             Boolean                         @default(true)
  privacyOrganization            Boolean                         @default(true)
  privacyDepartment              Boolean                         @default(true)
  privacyPosition                Boolean                         @default(true)
  privacyUrl                     Boolean                         @default(true)
  privacyAddress                 Boolean                         @default(true)
  privacyBio                     Boolean                         @default(true)
  privacyEmail                   Boolean                         @default(true)
  privacyWorkPhone               Boolean                         @default(true)
  privacyExtension               Boolean                         @default(true)
  privacyMobilePhone             Boolean                         @default(true)
  privacyBirthDate               Boolean                         @default(false)
  orgChartLabel                  String?
  /// 組織図の同階層内の並び順（左から0,1,2,...）
  orgChartOrder                  Int?
  description                    String?
  isRenoCrmUser                  Boolean                         @default(false)
  employmentType                 EmploymentType?
  weeklyPattern                  Int?
  configVersion                  String?
  vacationPattern                String?
  isPersonnelEvaluationTarget    Boolean                         @default(false)
  isNumericGoalEnabled           Boolean                         @default(true)
  personnelEvaluationTeamId      String?
  personnelEvaluationPatternId   String?
  activityLogs                   ActivityLog[]
  alertEvents                    AlertEvent[]
  attendance                     Attendance[]
  auditLogs                      AuditLog[]
  createdBoards                  Board[]                         @relation("BoardCreator")
  cardMembers                    CardMember[]
  createdCards                   Card[]                          @relation("CardCreator")
  consumptions                   Consumption[]
  convenienceCategoriesUpdated   ConvenienceCategory[]           @relation("ConvenienceCategoryUpdatedBy")
  convenienceCategoriesCreated   ConvenienceCategory[]           @relation("ConvenienceCategoryCreatedBy")
  convenienceEntriesUpdated      ConvenienceEntry[]              @relation("ConvenienceEntryUpdatedBy")
  convenienceEntriesCreated      ConvenienceEntry[]              @relation("ConvenienceEntryCreatedBy")
  customFolders                  CustomFolder[]                  @relation("CustomFolderEmployee")
  personnelEvaluationPattern     PersonnelEvaluationPattern?     @relation(fields: [personnelEvaluationPatternId], references: [id])
  personnelEvaluationTeam        PersonnelEvaluationTeam?        @relation(fields: [personnelEvaluationTeamId], references: [id])
  evaluations                    Evaluation[]
  familyMembers                  FamilyMember[]
  files                          File[]
  folders                        Folder[]
  grantLots                      GrantLot[]
  leaveRequests                  LeaveRequest[]
  payroll                        Payroll[]
  payrollChatworkSetting         PayrollChatworkSetting?
  personnelEvaluationGoals       PersonnelEvaluationGoal[]
  personnelEvaluationPointLogs   PersonnelEvaluationPointLog[]
  personnelEvaluationSubmissions PersonnelEvaluationSubmission[]
  taskMembers                    TaskMember[]
  assignedTasks                  Task[]                          @relation("TaskAssignee")
  timeOffRequests                TimeOffRequest[]
  userSettings                   UserSettings[]                  @relation("UserSettingsEmployee")
  vacationBalances               VacationBalance[]
  vacationRequests               VacationRequest[]
  workClockWorkers               WorkClockWorker?
  workspaceMembers               WorkspaceMember[]
  createdWorkspaces              Workspace[]                     @relation("WorkspaceCreator")

  @@map("employees")
}

model Evaluation {
  id         String   @id @default(cuid())
  employeeId String
  period     String
  evaluator  String
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("evaluations")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      String       @default("todo")
  priority    String       @default("medium")
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  employeeId  String
  members     TaskMember[]
  employee    Employee     @relation("TaskAssignee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model TaskMember {
  id         String   @id @default(cuid())
  taskId     String
  employeeId String
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, employeeId])
  @@map("task_members")
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  status     String    @default("present")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("attendance")
}

model Payroll {
  id         String   @id @default(cuid())
  employeeId String
  period     String
  amount     Float
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("payroll")
}

model File {
  id           String   @id @default(cuid())
  employeeId   String
  originalName String
  filename     String
  filePath     String?
  s3Key        String?
  mimeType     String
  fileSize     Int
  category     String
  folderName   String?
  taskId       String?
  createdAt    DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("files")
}

model Folder {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  parent     Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children   Folder[] @relation("FolderHierarchy")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("folders")
}

model PayrollChatworkSetting {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  chatworkRoomId String
  defaultMessage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("payroll_chatwork_settings")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  module    String
  details   String
  metadata  Json?
  createdAt DateTime @default(now())
  user      Employee @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  type       String
  reason     String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  description String?
  createdBy   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  boards      Board[]
  members     WorkspaceMember[]
  creator     Employee?         @relation("WorkspaceCreator", fields: [createdBy], references: [id])

  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  employeeId  String
  role        String    @default("member")
  createdAt   DateTime  @default(now())
  employee    Employee  @relation(fields: [employeeId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, employeeId])
  @@map("workspace_members")
}

model Board {
  id          String      @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdBy   String?
  position    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lists       BoardList[]
  creator     Employee?   @relation("BoardCreator", fields: [createdBy], references: [id])
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cards       Card[]

  @@map("boards")
}

model BoardList {
  id        String   @id @default(cuid())
  title     String
  position  Int
  boardId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]

  @@map("board_lists")
}

model Card {
  id          String       @id @default(cuid())
  title       String
  description String?
  position    Int
  listId      String
  boardId     String
  createdBy   String?
  attachments Json?
  labels      Json?
  checklists  Json?
  dueDate     DateTime?
  priority    String       @default("medium")
  status      String       @default("todo")
  cardColor   String?
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     CardMember[]
  creator     Employee?    @relation("CardCreator", fields: [createdBy], references: [id])
  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  list        BoardList    @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@map("cards")
}

model CardMember {
  id         String   @id @default(cuid())
  cardId     String
  employeeId String
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, employeeId])
  @@map("card_members")
}

model FamilyMember {
  id           String    @id @default(cuid())
  employeeId   String
  name         String
  relationship String
  birthDate    DateTime?
  phone        String?
  address      String?
  myNumber     String?
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("family_members")
}

model CustomFolder {
  id         String   @id @default(cuid())
  employeeId String
  category   String   @default("employee")
  name       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation("CustomFolderEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("custom_folders")
}

model UserSettings {
  id         String   @id @default(cuid())
  employeeId String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation("UserSettingsEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, key])
  @@map("user_settings")
}

model MasterData {
  id        String   @id @default(cuid())
  type      String
  value     String
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, value])
  @@map("master_data")
}

model VacationSettings {
  id                   String   @id @default(cuid())
  initialGrantPeriod   Int
  grantPeriod          Int
  carryOverLimit       Int
  validityYears        Int
  minimumMandatoryDays Int
  fullTimeGrantDays    Int
  partTime1DayGrant    Int
  partTime2DayGrant    Int
  partTime3DayGrant    Int
  partTime4DayGrant    Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("vacation_settings")
}

model VacationGrantSchedule {
  id                String   @id @default(cuid())
  serviceYears      Float
  fullTimeGrantDays Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("vacation_grant_schedule")
}

model PartTimeGrantSchedule {
  id              String   @id @default(cuid())
  serviceDays     Int
  workDaysPerWeek Int
  grantDays       Int
  annualMinDays   Int
  annualMaxDays   Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([serviceDays, workDaysPerWeek])
  @@map("parttime_grant_schedule")
}

model VacationBalance {
  id            String          @id @default(cuid())
  employeeId    String
  grantDate     DateTime
  grantDays     Int
  remainingDays Float
  expiryDate    DateTime
  isExpired     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  usages        VacationUsage[]

  @@index([employeeId, grantDate])
  @@map("vacation_balances")
}

model VacationRequest {
  id           String          @id @default(cuid())
  employeeId   String
  startDate    DateTime
  endDate      DateTime
  usedDays     Float
  reason       String?
  status       RequestStatus
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  employee     Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  usageDetails VacationUsage[]

  @@map("vacation_requests")
}

model VacationUsage {
  id        String          @id @default(cuid())
  requestId String
  balanceId String
  usedDays  Float
  createdAt DateTime        @default(now())
  balance   VacationBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  request   VacationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("vacation_usage")
}

model AlertSettings {
  id                    String   @id @default(cuid())
  alert3MonthsBefore    Boolean  @default(true)
  alert3MonthsThreshold Int      @default(5)
  alert2MonthsBefore    Boolean  @default(true)
  alert2MonthsThreshold Int      @default(3)
  alert1MonthBefore     Boolean  @default(true)
  alert1MonthThreshold  Int      @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("alert_settings")
}

model GrantLot {
  id            String        @id @default(cuid())
  employeeId    String
  grantDate     DateTime
  daysGranted   Decimal
  daysRemaining Decimal
  expiryDate    DateTime
  dedupKey      String        @unique
  configVersion String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  consumptions  Consumption[]
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, grantDate])
  @@map("grant_lots")
}

model Consumption {
  id         String         @id @default(cuid())
  employeeId String
  requestId  String
  lotId      String
  date       DateTime
  daysUsed   Decimal
  createdAt  DateTime       @default(now())
  lot        GrantLot       @relation(fields: [lotId], references: [id], onDelete: Cascade)
  request    TimeOffRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@index([lotId])
  @@index([requestId])
  @@map("consumptions")
}

model TimeOffRequest {
  id            String        @id @default(cuid())
  employeeId    String
  startDate     DateTime
  endDate       DateTime
  unit          RequestUnit
  hoursPerDay   Int?
  status        RequestStatus @default(PENDING)
  approvedAt    DateTime?
  totalDays     Decimal?
  breakdownJson String?
  reason        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  supervisorId  String?
  approvedBy    String?
  finalizedBy   String?
  consumptions  Consumption[]
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([supervisorId])
  @@map("time_off_requests")
}

model AlertEvent {
  id            String   @id @default(cuid())
  employeeId    String
  kind          String
  referenceDate DateTime
  details       String
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, kind, referenceDate])
  @@index([employeeId])
  @@map("alert_events")
}

model AuditLog {
  id         String    @id @default(cuid())
  employeeId String?
  actor      String
  action     String
  entity     String
  payload    String
  createdAt  DateTime  @default(now())
  employee   Employee? @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([action])
  @@map("audit_logs")
}

model VacationAppConfig {
  id         String   @id @default(cuid())
  version    String   @unique
  configJson String
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("vacation_app_configs")
}

model BulletinCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  color     String     @default("secondary")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  bulletins Bulletin[]

  @@map("bulletin_categories")
}

model Bulletin {
  id          String            @id @default(cuid())
  title       String
  content     String
  pinned      Boolean           @default(false)
  publishedAt DateTime          @default(now())
  categoryId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  category    BulletinCategory? @relation(fields: [categoryId], references: [id])

  @@index([publishedAt])
  @@map("bulletins")
}

model ConvenienceCategory {
  id            String             @id @default(cuid())
  tenantId      String?
  name          String
  position      Int                @default(0)
  isArchived    Boolean            @default(false)
  isAdminOnly   Boolean            @default(false)
  deletedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  createdBy     String?
  updatedBy     String?
  updatedByUser Employee?          @relation("ConvenienceCategoryUpdatedBy", fields: [updatedBy], references: [id])
  createdByUser Employee?          @relation("ConvenienceCategoryCreatedBy", fields: [createdBy], references: [id])
  entries       ConvenienceEntry[]

  @@index([tenantId, position])
  @@map("convenience_categories")
}

model ConvenienceEntry {
  id            String                @id @default(cuid())
  categoryId    String
  title         String
  note          String?
  position      Int                   @default(0)
  isArchived    Boolean               @default(false)
  isAdminOnly   Boolean               @default(false)
  deletedAt     DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  createdBy     String?
  updatedBy     String?
  updatedByUser Employee?             @relation("ConvenienceEntryUpdatedBy", fields: [updatedBy], references: [id])
  createdByUser Employee?             @relation("ConvenienceEntryCreatedBy", fields: [createdBy], references: [id])
  category      ConvenienceCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  urls          ConvenienceEntryUrl[]

  @@index([categoryId, position])
  @@map("convenience_entries")
}

model ConvenienceEntryUrl {
  id          String           @id @default(cuid())
  entryId     String
  url         String
  description String?
  position    Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  entry       ConvenienceEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, position])
  @@map("convenience_entry_urls")
}

model WorkClockWorker {
  id                      String                         @id @default(cuid())
  employeeId              String                         @unique
  name                    String
  password                String?
  companyName             String?
  qualifiedInvoiceNumber  String?
  chatworkId              String?
  email                   String
  phone                   String?
  address                 String?
  hourlyRate              Float
  wagePatternLabelA       String?                        @default("Aパターン")
  wagePatternLabelB       String?                        @default("Bパターン")
  wagePatternLabelC       String?                        @default("Cパターン")
  hourlyRateB             Float?
  hourlyRateC             Float?
  countPatternLabelA      String?                        @default("回数Aパターン")
  countPatternLabelB      String?                        @default("回数Bパターン")
  countPatternLabelC      String?                        @default("回数Cパターン")
  countRateA              Float?
  countRateB              Float?
  countRateC              Float?
  monthlyFixedAmount      Int?
  monthlyFixedEnabled     Boolean                        @default(false)
  invoiceUnregistered     Boolean                        @default(false)
  invoiceAdjustmentRate   Float?
  billingTaxEnabled       Boolean                        @default(false)
  billingTaxRate          Float?
  taxType                 String                         @default("exclusive")
  withholdingTaxEnabled   Boolean                        @default(false)
  withholdingHourlyA      Boolean                        @default(false)
  withholdingHourlyB      Boolean                        @default(false)
  withholdingHourlyC      Boolean                        @default(false)
  withholdingCountA       Boolean                        @default(false)
  withholdingCountB       Boolean                        @default(false)
  withholdingCountC       Boolean                        @default(false)
  withholdingMonthlyFixed Boolean                        @default(false)
  teams                   String?
  role                    String                         @default("worker")
  notes                   String?
  transferDestination     String?
  billingClientId         String?
  allowPastEntryEdit      Boolean                        @default(false)
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  isChecklistEnabled      Boolean                        @default(false)
  checklistSubmissions    WorkClockChecklistSubmission[]
  rewardPresets           WorkClockRewardPreset[]
  rewards                 WorkClockReward[]
  timeEntries             WorkClockTimeEntry[]
  billingClient           WorkClockBillingClient?        @relation(fields: [billingClientId], references: [id])
  employee                Employee                       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  checklistPatterns       WorkClockChecklistPattern[]    @relation("WorkClockChecklistPatternToWorkClockWorker")

  @@map("workclock_workers")
}

model WorkClockBillingClient {
  id        String            @id @default(cuid())
  name      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  workers   WorkClockWorker[]

  @@map("workclock_billing_clients")
}

model WorkClockTimeEntry {
  id           String          @id @default(cuid())
  workerId     String
  date         DateTime
  wagePattern  WagePattern?    @default(A)
  startTime    String
  endTime      String
  breakMinutes Int             @default(0)
  notes        String?
  countPattern WagePattern?
  count        Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  worker       WorkClockWorker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, date])
  @@map("workclock_time_entries")
}

model WorkClockReward {
  id          String          @id @default(cuid())
  workerId    String
  amount      Int
  description String
  date        DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  worker      WorkClockWorker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, date])
  @@map("workclock_rewards")
}

model WorkClockRewardPreset {
  id          String          @id @default(cuid())
  workerId    String
  amount      Int
  description String
  isEnabled   Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  worker      WorkClockWorker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("workclock_reward_presets")
}

model WorkClockTeam {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workclock_teams")
}

model WorkClockChecklistPattern {
  id          String                         @id @default(cuid())
  name        String
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt
  items       WorkClockChecklistItem[]
  submissions WorkClockChecklistSubmission[]
  workers     WorkClockWorker[]              @relation("WorkClockChecklistPatternToWorkClockWorker")

  @@map("workclock_checklist_patterns")
}

model WorkClockChecklistItem {
  id            String                    @id @default(cuid())
  patternId     String
  title         String
  reward        Float                     @default(0)
  isMandatory   Boolean                   @default(false)
  isFreeText    Boolean                   @default(false)
  isDescription Boolean                   @default(false)
  category      String?
  position      Int                       @default(0)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  pattern       WorkClockChecklistPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@index([patternId])
  @@map("workclock_checklist_items")
}

model WorkClockChecklistSubmission {
  id            String                             @id @default(cuid())
  workerId      String
  date          DateTime
  patternId     String?
  memo          String?
  photoUrl      String?
  hasPhoto      Boolean                            @default(false)
  isSafetyAlert Boolean                            @default(false)
  createdAt     DateTime                           @default(now())
  updatedAt     DateTime                           @updatedAt
  photos        WorkClockChecklistPhoto[]
  items         WorkClockChecklistSubmissionItem[]
  pattern       WorkClockChecklistPattern?         @relation(fields: [patternId], references: [id])
  worker        WorkClockWorker                    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, date])
  @@map("workclock_checklist_submissions")
}

model WorkClockChecklistSubmissionItem {
  id            String                       @id @default(cuid())
  submissionId  String
  title         String
  reward        Float
  isMandatory   Boolean
  isChecked     Boolean
  isFreeText    Boolean                      @default(false)
  isDescription Boolean                      @default(false)
  freeTextValue String?
  category      String?
  createdAt     DateTime                     @default(now())
  submission    WorkClockChecklistSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("workclock_checklist_submission_items")
}

model WorkClockChecklistPhoto {
  id           String                       @id @default(cuid())
  submissionId String
  url          String
  createdAt    DateTime                     @default(now())
  submission   WorkClockChecklistSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("workclock_checklist_photos")
}

model WorkClockAIReport {
  id          String   @id @default(cuid())
  date        DateTime
  summary     String
  promptId    String?
  promptName  String?
  workerCount Int
  alerts      Int
  totalReward Int
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([createdBy])
  @@index([createdAt])
  @@map("workclock_ai_reports")
}

model PersonnelEvaluationTeam {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  members   Employee[]

  @@map("personnel_evaluation_teams")
}

model PersonnelEvaluationPattern {
  id          String                    @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  employees   Employee[]
  items       PersonnelEvaluationItem[]

  @@map("personnel_evaluation_patterns")
}

model PersonnelEvaluationItem {
  id          String                     @id @default(cuid())
  patternId   String
  title       String
  description String?
  points      Float                      @default(0)
  isMandatory Boolean                    @default(false)
  type        String                     @default("checkbox")
  position    Int                        @default(0)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  pattern     PersonnelEvaluationPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@index([patternId])
  @@map("personnel_evaluation_items")
}

model PersonnelEvaluationSubmission {
  id         String                              @id @default(cuid())
  employeeId String
  date       DateTime
  patternId  String?
  status     String                              @default("submitted")
  note       String?
  createdAt  DateTime                            @default(now())
  updatedAt  DateTime                            @updatedAt
  photos     PersonnelEvaluationPhoto[]
  items      PersonnelEvaluationSubmissionItem[]
  employee   Employee                            @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([date])
  @@map("personnel_evaluation_submissions")
}

model PersonnelEvaluationSubmissionItem {
  id              String                        @id @default(cuid())
  submissionId    String
  itemId          String?
  title           String
  points          Float
  isChecked       Boolean                       @default(false)
  textValue       String?
  thankYouTo      String?
  thankYouMessage String?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  description     String?
  submission      PersonnelEvaluationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("personnel_evaluation_submission_items")
}

model PersonnelEvaluationPhoto {
  id           String                        @id @default(cuid())
  submissionId String
  url          String
  createdAt    DateTime                      @default(now())
  comment      String?
  submission   PersonnelEvaluationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("personnel_evaluation_photos")
}

model PersonnelEvaluationGoal {
  id                       String   @id @default(cuid())
  employeeId               String
  period                   String
  contractTargetAmount     Decimal  @default(0)
  contractAchievedAmount   Decimal  @default(0)
  completionTargetAmount   Decimal  @default(0)
  completionAchievedAmount Decimal  @default(0)
  isLocked                 Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  employee                 Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@map("personnel_evaluation_goals")
}

model PersonnelEvaluationPointLog {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  points     Float
  type       String
  sourceId   String?
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@map("personnel_evaluation_point_logs")
}

model PersonnelEvaluationFiscalYear {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("personnel_evaluation_fiscal_years")
}

model PersonnelEvaluationAIReport {
  id            String   @id @default(cuid())
  startDate     DateTime
  endDate       DateTime
  summary       String
  promptId      String?
  promptName    String?
  employeeCount Int
  totalPoints   Float
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([startDate, endDate])
  @@index([createdBy])
  @@map("personnel_evaluation_ai_reports")
}

model PersonnelEvaluationConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("personnel_evaluation_config")
}

